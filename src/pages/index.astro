---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import headerDTP from "../assets/images/header-c.jpg";
import vonageLogo from "../assets/images/Vonage_logo.svg";
import googleLogo from "../assets/images/google-logo-transparent.png";
import singTelLogo from "../assets/images/Singtel_white.png";
import speaker1 from "../assets/images/no_image_found.png";
import speaker2 from "../assets/images/no_image_found.png";
import speaker3 from "../assets/images/no_image_found.png";
import venue1 from "../assets/images/no_image_found.png";
import venue2 from "../assets/images/no_image_found.png";
import venue3 from "../assets/images/no_image_found.png";
import venue4 from "../assets/images/no_image_found.png";
import venue5 from "../assets/images/no_image_found.png";
import venue6 from "../assets/images/no_image_found.png";
---

<Layout>
    <div class="flex flex-col gap-10 md:gap-20">
        <header class="relative w-full h-125 sm:h-137.5 md:h-150 xl:h-162.5">
            <Image
                src={headerDTP}
                alt="Header background"
                layout="full-width"
                class="absolute inset-0 w-full h-full object-cover"
                decoding="async"
                loading="eager"
            />
            <div
                class="absolute inset-0 bg-linear-to-b from-black/80 from-30% to-transparent to-100%"
            >
            </div>
            <div class="relative z-2 w-full max-w-5xl mx-auto px-5 py-5 h-full">
                <div class="flex items-center gap-2 sm:gap-8">
                    <div class="flex flex-col cursor-default">
                        <span
                            class="font-sans text-[8px] sm:text-[10px] font-normal text-white uppercase tracking-widest mb-2.5"
                            >organiser</span
                        >
                        <Image
                            src={vonageLogo}
                            alt="Vonage logo"
                            width="140"
                            height="46"
                            layout="constrained"
                            decoding="async"
                            loading="eager"
                            class="w-[clamp(96px,54.88px+10.5vw,160px)] h-auto transition-transform duration-300 hover:scale-105"
                        />
                    </div>
                    <div
                        class="h-14 w-0 sm:w-px opacity-0 sm:opacity-100 bg-linear-to-b from-transparent via-gray-2 to-transparent transition-all duration-300 ease-in-out"
                    >
                    </div>
                    <div class="flex items-center cursor-default w-full">
                        <div class="flex flex-col grow">
                            <span
                                class="font-sans text-[8px] sm:text-[10px] font-normal text-white uppercase mb-2"
                                >Partners</span
                            >
                            <div
                                class="flex flex-row items-center gap-4 sm:gap-6 grow h-auto"
                            >
                                <div class="shrink-0">
                                    <Image
                                        src={googleLogo}
                                        alt="Google logo"
                                        width="2182"
                                        height="719"
                                        layout="constrained"
                                        decoding="async"
                                        loading="eager"
                                        class="w-[clamp(64px,22.88px+10.5vw,128px)] h-auto transition-transform duration-300 hover:scale-105"
                                    />
                                </div>
                                <div class="shrink-0">
                                    <Image
                                        src={singTelLogo}
                                        alt="SingTel logo"
                                        width="1930"
                                        height="1055"
                                        layout="constrained"
                                        decoding="async"
                                        loading="eager"
                                        class="w-[clamp(59.2px,33.92px+7.57vw,96px)] h-auto mb-2 sm:mb-3.5 transition-transform duration-300 hover:scale-105"
                                    />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div
                    class="relative z-10 h-[calc(100%-56px)] sm:h-[calc(100%-88px)] flex flex-col justify-center"
                >
                    <div>
                        <h1
                            class="w-fit max-w-full sm:max-w-[70%] md:max-w-[60%]"
                        >
                            The Future of Messaging in APAC:
                        </h1>
                    </div>
                    <div
                        class="font-sans text-[clamp(16px,13.84px+0.602vw,20px)] text-white font-normal"
                    >
                        <div class="py-8">
                            <span>June 2026</span>
                            <br />
                            <a
                                href="https://www.vonage.com/"
                                target="_blank"
                                class="border-b border-white hover:border-transparent transition-colors duration-300 cursor-pointer"
                            >
                                Jarkata
                            </a>
                            <!-- <br>1 Raffles Place, L62, Singapore 048616 -->
                        </div>
                        <a
                            href="#registration-form"
                            class="inline-block bg-white text-black font-sans font-semibold py-2 px-6 rounded-lg border-2 border-white transition-all duration-300 shadow-lg hover:shadow-xl hover:scale-105 hover:bg-transparent hover:text-white"
                        >
                            Register Now
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <section>
            <div class="container">
                <h2>
                    Join us in Jarkata for the first dedicated Vonage RCS (Rich
                    Communication Services) event in APAC.
                </h2>
                <p>
                    As business messaging continues to evolve, RCS is emerging
                    as a powerful new channel for brands to deliver richer, more
                    interactive customer experiences - directly within the
                    native messaging app.
                </p>
                <p>
                    This invite-only, executive-level session brings together
                    experts from Vonage and Google to share global perspectives,
                    APAC readiness insights, and a live demonstration of RCS in
                    action. Attendees will gain practical clarity on how RCS is
                    shaping the future of customer engagement and what it means
                    for their 2026 messaging roadmap.
                </p>
                <h3 class="mt-10">
                    Future of Messaging: How RCS Will Transform Brand Engagement
                    in APAC.
                </h3>
                <ul>
                    <li>Messaging is entering a new era.</li>
                    <li>
                        RCS is more than the evolution of SMS. It enables
                        branded, interactive, and conversational experiences
                        that combine the reach of messaging with the richness of
                        app-like engagement.
                    </li>
                    <li>
                        With APAC entering a critical stage of RCS adoption,
                        this session will help you understand where the market
                        is heading and how to prepare for what's next.
                    </li>
                </ul>
            </div>
        </section>
        <section>
            <div class="container">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16">
                    <div class="flex flex-col gap-y-6 md:gap-y-8">
                        <div>
                            <h3 class="uppercase">
                                What you'll gain from this session.
                            </h3>
                            <p>
                                This session is designed to give you clear,
                                practical insight into how RCS is changing
                                business messaging — and what it means for APAC
                                in 2026.
                            </p>
                        </div>
                        <div>
                            <h4>The Global RCS Landscape in 2026.</h4>
                            <ul>
                                <li>
                                    Understand how RCS is being adopted across
                                    the US, Europe, and leading global markets
                                </li>
                                <li>
                                    See where APAC sits today, and what the next
                                    phase of rollout looks like
                                </li>
                                <li>
                                    Gain clarity on timelines, operator
                                    readiness, and ecosystem progress
                                </li>
                            </ul>
                        </div>
                        <div>
                            <h4>See How Leading Brands Are Using RCS.</h4>
                            <ul>
                                <li>
                                    Learn how enterprises are driving higher
                                    engagement and conversion with RCS
                                </li>
                                <li>
                                    Understand how RCS compares to SMS,
                                    WhatsApp, and email
                                </li>
                                <li>
                                    Explore high-impact use cases across retail,
                                    BFSI, travel, logistics, and eCommerce
                                </li>
                            </ul>
                        </div>
                        <div>
                            <h4>Experience RCS in Action.</h4>
                            <ul>
                                <li>
                                    Watch a live RCS demo featuring rich media
                                    and branded messaging
                                </li>
                                <li>
                                    See how verified senders and conversational
                                    journeys build trust
                                </li>
                                <li>
                                    Explore AI-enabled customer interactions in
                                    the native messaging inbox
                                </li>
                            </ul>
                        </div>
                        <div>
                            <h4>Prepare for Commercialisation.</h4>
                            <ul>
                                <li>
                                    Understand what it takes to launch RCS at
                                    scale in APAC
                                </li>
                                <li>
                                    Learn how to integrate RCS into your
                                    existing marketing and CX stack
                                </li>
                                <li>
                                    Take away practical inputs for your 2026
                                    messaging roadmap
                                </li>
                            </ul>
                        </div>
                        <div>
                            <h4>Connect with Industry Experts.</h4>
                            <ul>
                                <li>Hear directly from Vonage and Google</li>
                                <li>
                                    Connect with peers shaping the future of
                                    business messaging in APAC
                                </li>
                            </ul>
                        </div>
                    </div>
                    <div class="w-full" id="registration-form">
                        <div
                            class="w-full px-6 py-10 sm:py-12 rounded-2xl bg-gray-3"
                        >
                            <div class="pb-2 sm:pb-4">
                                <h2>Register here</h2>
                            </div>
                            <form
                                class="js-cm-form"
                                id="subForm"
                                action="https://www.createsend.com/t/subscribeerror?description="
                                method="post"
                                data-id="191722FC90141D02184CB1B62AB3DC264E447864977B16BD6C39AEC0ECE3E6CC82ADEFE961779B23BFA73FF43059EBFCEC6F8C719E4E79C0AF4E3FEDCCD6F653"
                            >
                                <div class="flex flex-col gap-y-4 sm:gap-y-6">
                                    <div>
                                        <label for="fieldName"
                                            >First Name<!-- -->
                                        </label>
                                        <input
                                            id="fieldName"
                                            maxlength="200"
                                            name="cm-name"
                                            placeholder=""
                                            required=""
                                        />
                                    </div>
                                    <div>
                                        <label for="fieldtdcfl"
                                            >Last Name<!-- -->
                                        </label>
                                        <input
                                            id="fieldtdcfl"
                                            maxlength="200"
                                            name="cm-f-tdcfl"
                                            required=""
                                        />
                                    </div>
                                    <div>
                                        <label for="fieldtdcfr"
                                            >Company Name<!-- -->
                                        </label>
                                        <input
                                            id="fieldtdcfr"
                                            maxlength="200"
                                            name="cm-f-tdcfr"
                                            required=""
                                        />
                                    </div>
                                    <div>
                                        <label for="fieldtdcfy"
                                            >Job Title<!-- -->
                                        </label>
                                        <input
                                            id="fieldtdcfy"
                                            maxlength="200"
                                            name="cm-f-tdcfy"
                                            required=""
                                        />
                                    </div>
                                    <div>
                                        <label for="fieldEmail"
                                            >Email<!-- -->
                                        </label>
                                        <input
                                            autocomplete="Email"
                                            class="js-cm-email-input qa-input-email"
                                            id="fieldEmail"
                                            maxlength="200"
                                            name="cm-tdlkykt-tdlkykt"
                                            placeholder=""
                                            required=""
                                            type="email"
                                        />
                                    </div>

                                    <div
                                        class="flex flex-col lg:flex-row gap-2 space-y-4"
                                    >
                                        <div class="shrink-0">
                                            <label for="countryCode"
                                                >Country Code<!-- -->
                                            </label>
                                            <span>
                                                <select
                                                    id="fieldtdcfi"
                                                    name="cm-fo-tdcfi"
                                                    required=""
                                                >
                                                    <option disabled="" value=""
                                                        >Select...</option
                                                    >
                                                    <option
                                                        value="2453813"
                                                        selected
                                                        >+65 (SG)</option
                                                    >
                                                    <option value="2453814"
                                                        >+60 (MY)</option
                                                    >
                                                    <option value="2453815"
                                                        >+62 (ID)</option
                                                    >
                                                    <option value="2453816"
                                                        >+63 (PH)</option
                                                    >
                                                    <option value="2453817"
                                                        >+66 (TH)</option
                                                    >
                                                    <option value="2453818"
                                                        >+84 (VN)</option
                                                    >
                                                    <option value="2453822"
                                                        >+86 (CN)</option
                                                    >
                                                    <option value="2453823"
                                                        >+852 (HK)</option
                                                    >
                                                    <option value="2453824"
                                                        >+61 (AU)</option
                                                    >
                                                    <option value="2453825"
                                                        >+64 (NZ)</option
                                                    >
                                                    <option value="2453826"
                                                        >+91 (IN)</option
                                                    >
                                                    <option value="2453827"
                                                        >+81 (JP)</option
                                                    >
                                                    <option value="2453819"
                                                        >+82 (KR)</option
                                                    >
                                                    <option value="2453820"
                                                        >+1 (US/CA)</option
                                                    >
                                                    <option value="2453821"
                                                        >+44 (UK)</option
                                                    >
                                                </select>
                                            </span>
                                        </div>
                                        <div class="flex-1">
                                            <label for="fieldtdcfd"
                                                >Phone Number<!-- -->
                                            </label>
                                            <input
                                                id="fieldtdcfd"
                                                maxlength="200"
                                                name="cm-f-tdcfd"
                                                required=""
                                                type="number"
                                                class="no-number-spinner"
                                            />
                                        </div>
                                    </div>
                                    <div>
                                        <label for="fieldtdczj"
                                            >Dietary Requirements<!-- -->
                                        </label>
                                        <input
                                            id="fieldtdczj"
                                            maxlength="200"
                                            name="cm-f-tdczj"
                                            placeholder="e.g., Vegetarian, Vegan, Gluten-free, etc."
                                            required=""
                                        />
                                    </div>
                                    <div class="flex gap-3">
                                        <div class="flex items-start gap-2">
                                            <input
                                                aria-required="false"
                                                id="cm-privacy-email"
                                                name="cm-privacy-email"
                                                type="checkbox"
                                                class="mt-0.5 shrink-0 rounded border-black text-black focus:ring-gray-500 size-5"
                                            /><label for="cm-privacy-email">
                                                By checking this box, you agree
                                                to be contacted via phone and
                                                email regarding your interest in
                                                our products and services. We
                                                will treat your data in
                                                accordance with our privacy
                                                policy.
                                            </label>
                                        </div>
                                        <input
                                            id="cm-privacy-email-hidden"
                                            name="cm-privacy-email-hidden"
                                            type="hidden"
                                            value="true"
                                        />
                                    </div>
                                </div>
                                <button class="mt-3" type="submit"
                                    >Register Now</button
                                >
                            </form>
                            <script
                                type="text/javascript"
                                src="https://js.createsend1.com/javascript/copypastesubscribeformlogic.js"
                            ></script>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <section>
            <div class="container text-center">
                <h3>Outline Agenda</h3>
                <p>
                    <span class="font-bold">
                        A structured day of insights, demos, and networking
                    </span>
                    <br />
                    Agenda is subject to change. Timings and sessions may be adjusted
                    if necessary.
                </p>
                <div
                    class="border h-160 flex items-center justify-center mt-12"
                    data-usal="fade-u duration-300 delay-200"
                >
                    <h2>TBA</h2>
                </div>
            </div>
        </section>
        <section
            class="bg-linear-to-br from-gray-3/10 via-white to-gray-1 py-20"
        >
            <div class="container text-center mySpace-y">
                <h3>Meet Our Expert Speakers</h3>
                <p>
                    Industry leaders sharing insights on the future of RCS
                    messaging
                </p>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-6">
                    <!-- Cards 1 -->
                    <div
                        class="group flex flex-col items-center bg-white pt-4 text-center rounded-lg shadow-md hover:shadow-xl transition-all duration-500"
                        data-usal="fade-u duration-300 delay-200"
                    >
                        <div
                            class="relative w-[clamp(160px,120px+10vw,208px)] h-[clamp(160px,120px+10vw,208px)] rounded-full overflow-hidden mb-4 shadow-lg group-hover:shadow-2xl group-hover:scale-105 transition-all duration-500"
                        >
                            <Image
                                src={speaker1}
                                alt="Speaker David Benjamin"
                                width="2000"
                                height="2000"
                                layout="constrained"
                                decoding="async"
                                loading="lazy"
                                class="object-cover w-full h-full"
                            />
                        </div>
                        <div>
                            <div class="w-full rounded-lg p-4">
                                <h4
                                    class="font-bold text-lg md:text-xl mb-1 text-black"
                                >
                                    David Creasey-Benjamin
                                </h4>
                                <p
                                    class="text-sm md:text-base text-gray-5 font-semibold leading-tight mb-1"
                                >
                                    Strategic Account<br />Manager
                                </p>
                                <p class="text-sm text-black font-medium">
                                    Vonage
                                </p>
                            </div>
                        </div>
                    </div>
                    <!--Cards 2-->
                    <div
                        class="group flex flex-col items-center text-center bg-white pt-4 rounded-lg shadow-md hover:shadow-xl transition-all duration-500"
                        data-usal="fade-u duration-300 delay-400"
                    >
                        <div
                            class="relative w-[clamp(160px,120px+10vw,208px)] h-[clamp(160px,120px+10vw,208px)] rounded-full overflow-hidden mb-4 shadow-lg group-hover:shadow-2xl group-hover:scale-105 transition-all duration-500"
                        >
                            <Image
                                src={speaker2}
                                alt="Speaker Mahendra Mane"
                                width="2000"
                                height="2000"
                                layout="constrained"
                                decoding="async"
                                loading="lazy"
                                class="object-cover w-full h-full"
                            />
                        </div>
                        <div>
                            <div class="w-full rounded-lg p-4">
                                <h4
                                    class="font-bold text-lg md:text-xl mb-1 text-black"
                                >
                                    Mahendra Mane
                                </h4>
                                <p
                                    class="text-sm md:text-base text-gray-5 font-semibold leading-tight mb-1"
                                >
                                    Customer Solution <br /> Architect
                                </p>
                                <p class="text-sm text-black font-medium">
                                    Vonage
                                </p>
                            </div>
                        </div>
                    </div>
                    <!--Card 3-->
                    <div
                        class="group flex flex-col items-center text-center bg-white pt-4 rounded-lg shadow-md hover:shadow-xl transition-all duration-500"
                        data-usal="fade-u duration-300 delay-600"
                    >
                        <div
                            class="relative w-[clamp(160px,120px+10vw,208px)] h-[clamp(160px,120px+10vw,208px)] rounded-full overflow-hidden mb-4 shadow-lg group-hover:shadow-2xl group-hover:scale-105 transition-all duration-500"
                        >
                            <Image
                                src={speaker3}
                                alt="Speaker Tian Ung Ping"
                                width="2000"
                                height="2000"
                                layout="full-width"
                                class="object-cover w-full h-full"
                            />
                        </div>
                        <div>
                            <div class="w-full rounded-lg p-4">
                                <h4
                                    class="font-bold text-lg md:text-xl mb-1 text-black"
                                >
                                    Tian Ung Ping
                                </h4>
                                <p
                                    class="text-sm md:text-base text-gray-5 font-semibold leading-tight mb-1"
                                >
                                    Associate Director, Enterprise Mobility
                                </p>
                                <p class="text-sm text-black font-medium">
                                    SingTel, Singapore
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section
            class="bg-linear-to-br from-gray-50 via-white to-gray-100 py-10 md:py-20 -my-10 md:-my-20"
        >
            <div class="container text-center mySpace-y">
                <h3>Venue</h3>
                <p>
                    <a
                        href="https://www.vonage.com/"
                        target="_blank"
                        class="border-b border-black hover:border-transparent transition-colors duration-300 cursor-pointer"
                    >
                        TBC
                    </a>
                    <br />
                    Address to be updated
                </p>
                <div
                    class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"
                >
                    <div
                        class="relative overflow-hidden rounded-lg shadow-lg hover:shadow-2xl transition-transform duration-500 hover:scale-105 aspect-video"
                        data-usal="fade-u duration-300"
                    >
                        <Image
                            src={venue1}
                            alt="HighHouse Venue View 1"
                            width={800}
                            layout="constrained"
                            class="object-cover w-full h-full"
                        />
                    </div>
                    <div
                        class="relative overflow-hidden rounded-lg shadow-lg hover:shadow-2xl transition-transform duration-500 hover:scale-105 aspect-video"
                        data-usal="fade-u duration-300 delay-200"
                    >
                        <Image
                            src={venue2}
                            alt="HighHouse Venue View 2"
                            width={800}
                            layout="constrained"
                            class="object-cover w-full h-full"
                        />
                    </div>
                    <div
                        class="relative overflow-hidden rounded-lg shadow-lg hover:shadow-2xl transition-transform duration-500 hover:scale-105 aspect-video"
                        data-usal="fade-u duration-300 delay-400"
                    >
                        <Image
                            src={venue3}
                            alt="HighHouse Venue View 3"
                            width={800}
                            layout="constrained"
                            class="object-cover w-full h-full"
                        />
                    </div>
                    <div
                        class="relative overflow-hidden rounded-lg shadow-lg hover:shadow-2xl transition-transform duration-500 hover:scale-105 aspect-video"
                        data-usal="fade-u duration-300 delay-200"
                    >
                        <Image
                            src={venue4}
                            alt="HighHouse Venue View 4"
                            width={800}
                            layout="constrained"
                            class="object-cover w-full h-full"
                        />
                    </div>
                    <div
                        class="relative overflow-hidden rounded-lg shadow-lg hover:shadow-2xl transition-transform duration-500 hover:scale-105 aspect-video"
                        data-usal="fade-u duration-300 delay-400"
                    >
                        <Image
                            src={venue5}
                            alt="HighHouse Venue View 5"
                            width={800}
                            layout="constrained"
                            class="object-cover w-full h-full"
                        />
                    </div>
                    <div
                        class="relative overflow-hidden rounded-lg shadow-lg hover:shadow-2xl transition-transform duration-500 hover:scale-105 aspect-video"
                        data-usal="fade-u duration-300 delay-600"
                    >
                        <Image
                            src={venue6}
                            alt="HighHouse Venue View 6"
                            width={800}
                            layout="constrained"
                            class="object-cover w-full h-full"
                        />
                    </div>
                </div>
            </div>
        </section>
        <footer class="bg-black py-8">
            <div
                class="w-full max-w-5xl px-5 mx-auto flex flex-col sm:flex-row justify-between items-center text-center"
            >
                <span class="text-gray-2 text-sm"> © 2026 Vonage </span>
                <span class="text-gray-2 text-sm"> All rights reserved. </span>
            </div>
        </footer>
    </div>
</Layout>
